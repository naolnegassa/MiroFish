# LLM API Configuration (supports any LLM API in OpenAI SDK format)
# Recommended: use Aliyun Bailian's qwen-plus model: https://bailian.console.aliyun.com/
# Note: high resource consumption, try simulations with less than 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP Memory Graph Configuration =====
# Free monthly quota is sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM Configuration (Optional) =====
# Note: if not using accelerated configuration, do not include the following items in the env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here